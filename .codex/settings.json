{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          { "type": "command", "command": "./.codex/hooks/protected-files-guard.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          { "type": "command", "command": "./.codex/hooks/file-size-warning.sh" },
          { "type": "command", "command": "./.codex/hooks/console-log-detector.sh" }
        ]
      }
    ]
  }
}
