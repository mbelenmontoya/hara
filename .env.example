# Supabase
# Get these from: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx  # New format (or legacy eyJ... works too)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx  # New format (or legacy eyJ... works too)

# Attribution Token Secret (32+ bytes)
# Generate with: openssl rand -base64 32
ATTRIBUTION_TOKEN_SECRET=your-secret-here

# Upstash Redis (Rate Limiting) - REQUIRED for production
# Get from: https://console.upstash.com → Create Redis → REST API tab
UPSTASH_REDIS_REST_URL=https://your-redis-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXaaaBBB...

# Vercel Cron Secret
CRON_SECRET=your-cron-secret

# Admin Auth (Clerk)
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
