# Supabase — names match what Supabase shows in Settings → API.
# NEXT_PUBLIC_* vars are exposed to the browser; non-prefixed are server-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx  # safe to expose; replaces legacy NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_URL=https://your-project.supabase.co            # same value, server-only client (lib/supabase-admin.ts)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx                  # NEVER expose; new format (legacy eyJ... still works)

# Attribution Token Secret (32+ bytes)
# Generate with: openssl rand -base64 32
ATTRIBUTION_TOKEN_SECRET=your-secret-here

# Upstash Redis (Rate Limiting) - REQUIRED for production
# Get from: https://console.upstash.com → Create Redis → REST API tab
UPSTASH_REDIS_REST_URL=https://your-redis-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXaaaBBB...

# Vercel Cron Secret
CRON_SECRET=your-cron-secret

# Admin Auth (Clerk)
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
