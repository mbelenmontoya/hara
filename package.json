{
  "name": "hara",
  "version": "1.0.0",
  "description": "Hará Match - Performance-based lead marketplace for wellness professionals",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "e2e:install": "playwright install chromium",
    "e2e:dev": "playwright test",
    "e2e:prod": "REQUIRE_ADMIN_AUTH=true playwright test",
    "qa:week4": "npm run test:integration && npm run e2e:prod",
    "lint": "next lint",
    "qa:rls-bypass": "tsx scripts/qa-rls-bypass.test.ts",
    "qa:service-smoke": "tsx scripts/qa-service-role-smoke.ts",
    "qa:week1": "tsx scripts/qa-seed.ts > qa.env && tsx scripts/qa-rls-bypass.test.ts && tsx scripts/qa-service-role-smoke.ts",
    "qa:week2": "tsx scripts/qa-seed.ts > qa.env && npm run test:integration"
  },
  "dependencies": {
    "@clerk/nextjs": "^5.0.0",
    "@fingerprintjs/fingerprintjs": "^4.2.0",
    "@supabase/supabase-js": "^2.39.0",
    "@upstash/ratelimit": "^1.0.0",
    "@upstash/redis": "^1.28.0",
    "dotenv": "^17.2.3",
    "jose": "^5.2.0",
    "nanoid": "^5.1.6",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "type": "module"
}
